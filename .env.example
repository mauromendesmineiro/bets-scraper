# ============================================================
# .env.example — copia para .env e preenche os valores reais
# NUNCA commitar o .env com valores reais!
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=supabase_url
SUPABASE_KEY=supabase_key

# ── Captcha (2captcha.com) ────────────────────────────────────
# Necessário apenas para os 6 sites com captcha
TWOCAPTCHA_API_KEY=2captcha_api_key

# ── Playwright ────────────────────────────────────────────────
HEADLESS=false       # false para desenvolvimento local, true em cloud
SLOW_MO=200          # ms entre acções (300 se quiser ver o browser a trabalhar)
DEFAULT_TIMEOUT=15000

# ── Comportamento do scraper ──────────────────────────────────
RATE_LIMIT_WAIT=65   # segundos de espera após rate limit
SLEEP_BETWEEN=3      # segundos entre contas
DAYS_WINDOW=3        # janela de dias do relatório

# ── Pastas locais ──────────────────────────────────────────────
DATA_DIR=data
LOGS_DIR=logs

# ── Envio de e-mail ────────────────────────────────────────────
SMTP_USER=seu_emaul@gmail.com
SMTP_PASSWORD=suapassword


NOTIFY_TO=email1@gmail.com  
NOTIFY_CC=email2@hotmail.com    
NOTIFY_BCC=email3@outlook.com 

# ── Passwords das contas ──────────────────────────────────────
# Convenção: PASS_{SLUG_PLATAFORMA}_{USERNAME_SANITIZADO}
# Substitui @, . e espaços por _ no username
#
# Exemplos:
PASS_PLATAFORMA1_JOAO_SILVA=senha123
PASS_PLATAFORMA2_MARIA_SANTOS=outrasenha
PASS_PLATAFORMA3_AFILIADO1_GMAIL_COM=pass456
PASS_PLATAFORMA4_USER_CASA=pass789
#
# Para 89 contas, gera este ficheiro automaticamente
# a partir do Excel original com o script tools/migrate_from_excel.py
